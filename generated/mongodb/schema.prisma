generator client {
  provider = "prisma-client-js"
  output   = "../../generated/mongodb"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URL")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Float
  createdAt   DateTime @default(now())
}
